{
  "schemaVersion": 1,
  "id": "rotproxy",
  "version": "${version}",
  "name": "RotProxy",
  "description": "Client-side Fabric proxy mod with proxy health checks, a kill switch, and a Multiplayer quick-config button.",
  "authors": ["RotProxy"],
  "contact": {},
  "license": "MIT",
  "icon": "assets/rotproxy/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.rotproxy.RotProxyMod"
    ]
  },
  "mixins": [
    "rotproxy.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.17.2",
    "fabric-api": "*",
    "minecraft": "${minecraft_dependency}",
    "java": ">=21"
  }
}
